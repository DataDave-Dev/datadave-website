---
import SectionLabel from "@/components/ui/SectionLabel.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

interface Props {
    overview: string[];
}
const { overview } = Astro.props;

const t = useTranslations(getLangFromUrl(Astro.url));
---

<section aria-labelledby="overview-title">
    <SectionLabel id="overview-title">{t("project.overviewLabel")}</SectionLabel>
    <div class="flex max-w-[60ch] flex-col gap-4">
        {
            overview.map((p) => (
                <p class="font-body text-base leading-relaxed text-[#cfc9c4] md:text-lg">
                    {p}
                </p>
            ))
        }
    </div>
</section>
