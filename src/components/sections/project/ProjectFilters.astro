---
// Filtros por tecnología para la página de Proyectos. Calcula los tags únicos
// (con su frecuencia) y filtra en cliente las tarjetas [data-project-card] por su
// atributo data-tags. Selección única + "Todos". Se reinicia en astro:page-load.
import { getProjects } from "@/const/projects";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const PROJECTS = getProjects(lang);

const counts = new Map<string, number>();
for (const p of PROJECTS) {
    for (const tag of p.tags) counts.set(tag, (counts.get(tag) ?? 0) + 1);
}
// Más usados primero; a igualdad, alfabético.
const tags = [...counts.entries()]
    .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
    .map(([tag]) => tag);
const total = PROJECTS.length;
---

<div class="filters" data-filters>
    <p class="filters__label">{t("projectsPage.filterLabel")}</p>

    <div class="filters__bar">
        <div
            class="filters__row"
            role="group"
            aria-label={t("projectsPage.filterAria")}
        >
            <button
                type="button"
                class="chip is-active"
                data-filter="all"
                aria-pressed="true">{t("projectsPage.filterAll")}</button
            >
            {
                tags.map((tag) => (
                    <button
                        type="button"
                        class="chip"
                        data-filter={tag.toLowerCase()}
                        aria-pressed="false"
                    >
                        {tag}
                    </button>
                ))
            }
        </div>

        <p
            class="filters__count"
            aria-live="polite"
            aria-label={t("projectsPage.countAria")}
        >
            <span class="filters__num" data-count>{total}</span>
            <span class="filters__sep">/</span>
            <span class="filters__total">{total}</span>
        </p>
    </div>

    <p class="filters__empty" data-no-results hidden>
        {t("projectsPage.noResults")}
    </p>
</div>

<style>
    .filters {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .filters__label {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--c-ember);
    }
    .filters__bar {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }
    .filters__row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
    }
    .chip {
        border: 1px solid #242424;
        padding: 0.32rem 0.7rem;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(237, 230, 224, 0.85);
        background: transparent;
        cursor: pointer;
        transition:
            color 0.25s ease,
            border-color 0.25s ease,
            background 0.25s ease;
    }
    .chip:hover,
    .chip:focus-visible {
        border-color: var(--c-salmon);
        color: var(--c-salmon);
    }
    .chip:focus-visible {
        outline: 2px solid var(--c-salmon);
        outline-offset: 2px;
    }
    .chip.is-active {
        border-color: var(--c-salmon);
        background: rgba(226, 163, 153, 0.12);
        color: var(--c-salmon);
    }
    .filters__count {
        margin: 0;
        flex-shrink: 0;
        font-family: var(--font-mono);
        font-size: 0.82rem;
        letter-spacing: 0.16em;
        color: var(--c-dim);
        font-variant-numeric: tabular-nums;
    }
    .filters__num {
        color: var(--c-salmon);
    }
    .filters__sep {
        margin: 0 0.4em;
        opacity: 0.6;
    }
    .filters__empty {
        margin: 0;
        border: 1px solid #1c1c1c;
        padding: 1.5rem;
        font-family: var(--font-mono);
        font-size: 0.85rem;
        color: var(--c-dim);
    }

    @media (prefers-reduced-motion: reduce) {
        .chip {
            transition: none;
        }
    }
</style>

<script>
    function initProjectFilters(): void {
        const bar = document.querySelector<HTMLElement>("[data-filters]");
        if (!bar || bar.dataset.ready) return;
        bar.dataset.ready = "1";

        const buttons = Array.from(
            bar.querySelectorAll<HTMLButtonElement>("[data-filter]"),
        );
        const cards = Array.from(
            document.querySelectorAll<HTMLElement>("[data-project-card]"),
        );
        const countEl = bar.querySelector<HTMLElement>("[data-count]");
        const empty = bar.querySelector<HTMLElement>("[data-no-results]");
        if (!buttons.length || !cards.length) return;

        function apply(filter: string): void {
            let shown = 0;
            cards.forEach((card) => {
                const tags = (card.dataset.tags ?? "").split("|");
                const match = filter === "all" || tags.includes(filter);
                card.hidden = !match;
                if (match) shown++;
            });
            buttons.forEach((b) => {
                const on = b.dataset.filter === filter;
                b.classList.toggle("is-active", on);
                b.setAttribute("aria-pressed", on ? "true" : "false");
            });
            if (countEl) countEl.textContent = String(shown);
            if (empty) empty.hidden = shown > 0;
        }

        buttons.forEach((b) =>
            b.addEventListener("click", () => apply(b.dataset.filter ?? "all")),
        );
    }

    document.addEventListener("astro:page-load", initProjectFilters);
</script>
