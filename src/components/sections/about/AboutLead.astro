---
import { FULL_NAME } from "@/const/profile";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="lead">
    <p class="kicker about-reveal">{t("about.leadKicker")}</p>
    <h1 id="about-title" class="title about-reveal">{t("about.title")}</h1>
    <span class="scrub-rule" aria-hidden="true"></span>
    <p
        class="about-reveal font-mono text-sm uppercase tracking-[0.25em] text-salmon"
    >
        {FULL_NAME}
    </p>
    <p class="intro about-reveal">
        <span class="prompt" aria-hidden="true">&gt;</span>
        {t("about.intro")}
    </p>
</section>

<style>
    .lead {
        display: flex;
        flex-direction: column;
        gap: clamp(0.85rem, 0.6rem + 1vw, 1.5rem);
    }
    .kicker {
        margin: 0;
        font-family: var(--font-mono);
        font-size: clamp(0.7rem, 0.65rem + 0.3vw, 0.85rem);
        font-weight: 500;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--c-dim);
        border-left: 3px solid var(--c-blood);
        padding-left: 0.9em;
    }
    .title {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 400;
        line-height: 0.85;
        font-size: clamp(3rem, 1rem + 13vw, 10rem);
        text-transform: uppercase;
        color: var(--c-bone);
        text-shadow: 0 0 0.4em rgba(255, 0, 0, 0.08);
    }
    .intro {
        margin: 0;
        max-width: 54ch;
        font-family: var(--font-body);
        font-size: clamp(1.05rem, 0.98rem + 0.45vw, 1.3rem);
        line-height: 1.65;
        color: #e2dcd6;
    }
    .prompt {
        color: var(--c-red);
        margin-right: 0.4em;
        font-weight: 700;
    }
    /* Acento que GSAP "dibuja" con el scroll (scrub). Base sin escala. */
    .scrub-rule {
        display: block;
        height: 2px;
        width: min(220px, 60%);
        background: var(--c-blood);
        transform: scaleX(0);
        transform-origin: left center;
    }
    @media (prefers-reduced-motion: reduce) {
        /* Sin JS/animación: la línea queda visible. */
        .scrub-rule {
            transform: scaleX(1);
        }
    }
</style>
