---
import { getProfile } from "@/const/profile";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const SKILLS = getProfile(lang).skills;
---

<section class="skills about-reveal">
    <h2 class="block-title">{t("about.skillsLabel")}</h2>
    <ul class="skill-list">
        {
            SKILLS.map((skill, i) => (
                <li>
                    <span class="skill-idx">{String(i + 1).padStart(2, "0")}</span>
                    {skill}
                </li>
            ))
        }
    </ul>
</section>

<style>
    .block-title {
        margin: 0 0 1rem;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--c-ember);
    }

    .skill-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0;
        border-top: 1px solid #1c1c1c;
    }
    .skill-list li {
        display: flex;
        align-items: baseline;
        gap: 0.9em;
        padding: 1.1rem 0.5rem;
        border-bottom: 1px solid #1c1c1c;
        font-family: var(--font-body);
        font-size: 1.05rem;
        color: var(--c-bone);
        transition:
            color 0.3s,
            background 0.3s,
            padding-left 0.3s var(--ease-out-expo);
    }
    .skill-list li:hover {
        color: var(--c-salmon);
        background: rgba(153, 0, 0, 0.06);
        padding-left: 1.2rem;
    }
    .skill-idx {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--c-red);
        letter-spacing: 0.1em;
    }
</style>
