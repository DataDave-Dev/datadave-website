---
import type { GetStaticPaths } from "astro";
import { LOCALES } from "@/i18n/config";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import Layout from "@/layouts/Layout.astro";
import CrtShell from "@/components/layout/CrtShell.astro";
import CareerTimeline from "@/components/sections/career/CareerTimeline.astro";
import { getCareer } from "@/const/career";
import { FULL_NAME } from "@/const/profile";

export const getStaticPaths = (() =>
    LOCALES.map((lang) => ({ params: { lang } }))) satisfies GetStaticPaths;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const career = getCareer(lang);
const isEmpty =
    !career.experience.length &&
    !career.education.length &&
    !career.achievements.length;
---

<Layout
    title={t("seo.careerTitle")}
    description={t("seo.careerDesc")}
    type="profile"
>
    <CrtShell
        mainId="career"
        channel={t("career.channel")}
        labelledby="career-title"
    >
        <section class="flex flex-col gap-4">
            <p
                class="border-l-[3px] border-blood pl-3.5 font-mono text-[0.78rem] font-medium uppercase tracking-[0.25em] text-dim"
            >
                {t("career.kicker")}
            </p>
            <h1
                id="career-title"
                class="font-display text-6xl uppercase leading-[0.9] text-bone md:text-8xl"
            >
                {t("career.title")}
            </h1>
            <p class="font-mono text-sm uppercase tracking-[0.25em] text-salmon">
                {FULL_NAME}
            </p>
            <p
                class="max-w-[60ch] font-body text-base leading-relaxed text-[#d6cfc9] md:text-lg"
            >
                <span class="mr-2 text-red" aria-hidden="true">&gt;</span>
                {t("career.intro")}
            </p>
        </section>

        <CareerTimeline
            label={t("career.experienceLabel")}
            entries={career.experience}
            id="experiencia"
        />
        <CareerTimeline
            label={t("career.educationLabel")}
            entries={career.education}
            id="formacion"
        />
        <CareerTimeline
            label={t("career.certsLabel")}
            entries={career.achievements}
            id="logros"
        />

        {
            isEmpty && (
                <p class="max-w-[48ch] border border-[#1c1c1c] bg-bg/40 p-6 font-mono text-sm leading-relaxed text-dim">
                    {t("career.empty")}
                </p>
            )
        }
    </CrtShell>
</Layout>
